{
    "name": "production-event/erp-sportif",
    "description": "ERP de gestion d'événements sportifs",
    "require": {
        "php": ">=8.4",
        "phpmailer/phpmailer": "6.11.0",
        "vlucas/phpdotenv": "5.6.2",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "phpstan/phpstan": "2.1.31",
        "squizlabs/php_codesniffer": "4.0.0",
        "phpunit/phpunit": "12.4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/app/",
            "Core\\": "src/Core/"
        }
    },
    "scripts": {
        "lint": "vendor/bin/phpcs --standard=phpcs.xml.dist --colors",
        "analyse": "vendor/bin/phpstan analyse --level=9",
        "test": "vendor/bin/phpunit"
    }
}